{
    "version": "0.2.0",
    "configurations": [
      {
        "name": "Next Server",
        "type": "node-terminal",
        "request": "launch",
        "command": "npm run dev"
      },
      {
        "name": "Next Client",
        "type": "chrome",
        "request": "launch",
        "url": "http://localhost:3000",
        "resolveSourceMapLocations": [
          "${workspaceFolder}/**",
          "!**/node_modules/**"
        ]
      },
    ]
  }